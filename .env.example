# Host environment for KnowledgeBase. Copy to `.env` (gitignored).
#
# Postgres is the sole source of truth. The compose `db` service publishes
# Postgres on localhost:15432; host-run tools (kb-lint, alembic, psql reads)
# reach it through DATABASE_URL.
#
# The kb-mcp FastMCP server (streamable-http, 127.0.0.1:8765, no auth token)
# is the write surface. KB_MCP_HOST/PORT are optional overrides for the defaults.

DATABASE_URL=postgresql+psycopg://knowledgebase:knowledgebase@localhost:15432/knowledgebase
# KB_MCP_HOST=127.0.0.1
# KB_MCP_PORT=8765
